{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "devCommand": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:date(\\d{4}-\\d{2}-\\d{2})",
      "destination": "/:date.html",
      "permanent": true
    },
    {
      "source": "/weekly-:week(\\d{4}-W\\d{2})",
      "destination": "/weekly-:week.html",
      "permanent": true
    }
  ]
}
